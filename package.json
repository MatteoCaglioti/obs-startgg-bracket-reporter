{
  "name": "obs-startgg-bracket-reporter",
  "version": "1.0.0",
  "main": "electron/main.js",
  "scripts": {
    "build:web": "cd web && npm ci && npm run build",
    "build:api": "cd api && npm ci && npm run build",
    "build": "npm run build:web && npm run build:api",
    "electron": "npm run build && electron .",
    "dist": "npm run build && electron-builder --win --x64 --publish never"
  },
  "build": {
    "appId": "com.obsstartgg.bracketreporter",
    "productName": "OBS StartGG Bracket Reporter",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "api/dist/**/*",
      "api/package.json",
      "api/node_modules/**/*",
      "web/dist/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^36.9.5",
    "electron-builder": "^26.8.1"
  }
}